---
import { Separator } from '@/components/ui/separator'
import { SOCIAL_LINKS } from '@/consts'
import Link from './link.astro'
import SocialIcons from './social-icons.astro'
---

<footer class="mx-auto mb-8 w-full max-w-3xl px-4 sm:mb-4">
  <!--
    FOOTER LINKS ROW
    ────────────────
    A row of navigation links sitting above the copyright bar.
    These link to utility/reference pages (tags, uses).
    To add a new footer link, just append a <Link> element here.
  -->
  <nav
    class="mb-4 flex items-center justify-center gap-x-4 text-sm"
    aria-label="Footer navigation"
  >
    <Link
      href="/tags"
      class="text-muted-foreground hover:text-accent transition-colors"
      >Tags</Link
    >
    <Separator orientation="vertical" className="h-4!" />
    <Link
      href="/setup"
      class="text-muted-foreground hover:text-accent transition-colors"
      >Setup</Link
    >
    <Separator orientation="vertical" className="h-4!" />
    <Link
      href="/legal"
      class="text-muted-foreground hover:text-accent transition-colors"
      >Legal</Link
    >
  </nav>

  <!--
    COPYRIGHT + SOCIAL ICONS
    ───────────────────────
    Original footer content: copyright, author credit, and social links.
  -->
  <div class="flex flex-wrap items-center justify-center gap-x-2 text-center">
    <span class="text-muted-foreground text-sm">
      &copy; {new Date().getFullYear()} All rights reserved.
    </span>
    <Separator orientation="vertical" className="hidden h-4! sm:block" />
    <p class="text-muted-foreground text-sm">
      Made with 🤍 based on <Link
        href="https://astro.build/themes/details/astro-erudite/"
        class="text-foreground"
        external
        underline>astro-erudite</Link
      > by <Link
        href={SOCIAL_LINKS.find((l) => l.label === 'GitHub')?.href || '#'}
        class="text-foreground"
        external
        underline>vanam</Link
      >!
    </p>
  </div>
  <div class="mt-4 flex items-center justify-center">
    <SocialIcons links={SOCIAL_LINKS} />
  </div>
</footer>
