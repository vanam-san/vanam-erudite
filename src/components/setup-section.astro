---
import { Icon } from 'astro-icon/components'

interface Props {
  title: string
  icon: string
  items: { name: string; description: string; icon: string }[]
}

const { title, icon, items } = Astro.props
---

<div class="flex flex-col gap-y-4">
  <div class="flex items-center gap-x-2">
    <Icon name={icon} class="size-5" />
    <h2 class="text-xl font-medium">{title}</h2>
  </div>
  <div class="flex flex-col gap-3">
    {
      items.map((item) => (
        <div class="border-border/50 bg-muted/30 flex gap-x-4 rounded-xl border p-4">
          <div class="bg-muted flex size-10 shrink-0 items-center justify-center rounded-lg">
            <Icon name={item.icon} class="text-muted-foreground size-5" />
          </div>
          <div class="flex flex-col gap-y-1">
            <h3 class="text-sm font-medium">{item.name}</h3>
            <p class="text-muted-foreground text-xs leading-relaxed">
              {item.description}
            </p>
          </div>
        </div>
      ))
    }
  </div>
</div>
