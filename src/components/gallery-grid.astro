---
/**
 * gallery-grid.astro
 * ───────────────────
 * Responsive masonry grid for displaying gallery photos.
 * Uses Astro's <Image /> component for optimized WebP output.
 * Includes a vanilla JS lightbox for full-screen image viewing.
 *
 * Props:
 *   - photos: Array of ImageMetadata from the gallery collection
 *   - title: Optional title for alt text on images
 *
 * Usage:
 *   <GalleryGrid photos={gallery.data.photos} title="My Album" />
 */
import type { ImageMetadata } from 'astro'
import { getImage, Image } from 'astro:assets'

interface Props {
  photos: ImageMetadata[]
  title?: string
}

const { photos, title = '' } = Astro.props

const lightboxImages = await Promise.all(
  photos.map((photo) =>
    getImage({
      src: photo,
      width: photo.width,
      height: photo.height,
      format: 'WEBP',
    }),
  ),
)
---

<div
  id="gallery-grid"
  class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3"
>
  {
    photos.map((photo, index) => (
      <button
        class="gallery-thumb cursor-pointer overflow-hidden rounded-xl border"
        data-index={index}
        data-lightbox-src={lightboxImages[index].src}
        aria-label={`${title ? `${title} - ` : ''}Gallery photo ${index + 1}`}
      >
        <Image
          src={photo}
          alt={
            title
              ? `${title} - Photo ${index + 1}`
              : `Gallery photo ${index + 1}`
          }
          width={600}
          height={600}
          loading="lazy"
          class="aspect-square w-full object-cover transition-transform duration-300 hover:scale-105"
        />
      </button>
    ))
  }
</div>

<!--
  LIGHTBOX SCRIPT
  ───────────────
  Creates a full-screen overlay for viewing images.
  Supports keyboard navigation (Escape to close, arrows to navigate).
  Triggered by clicking any .gallery-thumb button.
-->
<script>
  function initLightbox() {
    const thumbs = document.querySelectorAll(
      '.gallery-thumb',
    ) as NodeListOf<HTMLElement>
    if (!thumbs.length) return

    const images: { src: string; alt: string }[] = []
    thumbs.forEach((thumb) => {
      const src = thumb.getAttribute('data-lightbox-src')
      const alt = thumb.getAttribute('aria-label') || ''
      if (src) images.push({ src, alt })
    })

    if (document.getElementById('lightbox-overlay')) return
    const overlay = document.createElement('div')
    overlay.id = 'lightbox-overlay'
    overlay.className =
      'fixed inset-0 z-50 flex items-center justify-center bg-black/80 opacity-0 pointer-events-none transition-opacity duration-300'
    overlay.innerHTML = `
      <button id="lb-close" aria-label="Close lightbox" class="absolute top-4 right-4 z-10 flex size-10 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/20 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <button id="lb-prev" aria-label="Previous image" class="absolute left-4 top-1/2 z-10 flex size-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/20 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <img id="lb-image" alt="" class="max-h-[90vh] max-w-[90vw] rounded-lg object-contain" />
      <button id="lb-next" aria-label="Next image" class="absolute right-4 top-1/2 z-10 flex size-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/10 text-white hover:bg-white/20 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      </button>
      <div id="lb-counter" class="absolute bottom-4 left-1/2 z-10 -translate-x-1/2 rounded-full bg-white/10 px-3 py-1 text-sm text-white"></div>
    `
    document.body.appendChild(overlay)

    const lbImage = overlay.querySelector(
      '#lb-image',
    ) as HTMLImageElement | null
    const lbCounter = overlay.querySelector('#lb-counter')
    const lbClose = overlay.querySelector(
      '#lb-close',
    ) as HTMLButtonElement | null
    const lbPrev = overlay.querySelector('#lb-prev') as HTMLButtonElement | null
    const lbNext = overlay.querySelector('#lb-next') as HTMLButtonElement | null
    let current = 0

    function show() {
      if (!lbImage || !lbCounter || !lbClose) return
      lbImage.src = images[current].src
      lbImage.alt = images[current].alt
      lbCounter.textContent = `${current + 1} / ${images.length}`
      overlay.classList.remove('pointer-events-none', 'opacity-0')
      document.body.style.overflow = 'hidden'
      lbClose.focus()
    }

    function hide() {
      overlay.classList.add('pointer-events-none', 'opacity-0')
      document.body.style.overflow = ''
      thumbs[current]?.focus()
    }

    thumbs.forEach((thumb, i) => {
      thumb.addEventListener('click', () => {
        current = i
        show()
      })
    })

    lbClose?.addEventListener('click', hide)
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) hide()
    })
    lbPrev?.addEventListener('click', () => {
      current = (current - 1 + images.length) % images.length
      show()
    })
    lbNext?.addEventListener('click', () => {
      current = (current + 1) % images.length
      show()
    })

    document.addEventListener('keydown', (e) => {
      if (overlay.classList.contains('pointer-events-none')) return
      if (e.key === 'Escape') hide()
      if (e.key === 'ArrowLeft') {
        current = (current - 1 + images.length) % images.length
        show()
      }
      if (e.key === 'ArrowRight') {
        current = (current + 1) % images.length
        show()
      }
      if (e.key === 'Tab' && lbPrev && lbNext && lbClose) {
        const focusable = [lbPrev, lbNext, lbClose]
        const first = focusable[0]
        const last = focusable[focusable.length - 1]
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault()
          last.focus()
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault()
          first.focus()
        }
      }
    })
  }

  document.addEventListener('astro:page-load', initLightbox)
</script>
