---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import Card from '@/components/card.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import SectionHeading from '@/components/section-heading.astro'
import Layout from '@/layouts/layout.astro'
import { getAllGalleries } from '@/lib/data-utils'
import { Image } from 'astro:assets'

const galleries = await getAllGalleries()
---

<Layout class="max-w-3xl">
  <PageHead
    slot="head"
    title="Gallery"
    description="A visual collection of photography and visual projects."
  />
  <Breadcrumbs items={[{ label: 'Gallery', icon: 'lucide:image' }]} />

  <section class="flex flex-col gap-y-6">
    <SectionHeading
      title="Gallery"
      description="A visual collection of photography and visual projects."
    />

    {
      galleries.length > 0 ? (
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {galleries.map((gallery) => (
            <Card class="hover:border-accent/50 hover:bg-muted/50 !p-3">
              <Link
                href={`/gallery/${gallery.id}`}
                class="inline-flex w-full flex-col gap-y-3"
              >
                <div class="overflow-hidden rounded-lg">
                  <Image
                    src={gallery.data.cover}
                    alt={gallery.data.title}
                    width={800}
                    height={600}
                    loading="lazy"
                    class="h-auto w-full object-cover transition-transform duration-300 hover:scale-105"
                  />
                </div>
                <div class="flex flex-col gap-y-1.5 px-1">
                  <h3 class="text-sm leading-tight font-medium">
                    {gallery.data.title}
                  </h3>
                  <p class="text-muted-foreground line-clamp-2 text-xs">
                    {gallery.data.description}
                  </p>
                  <p class="text-muted-foreground/70 text-xs">
                    {`${gallery.data.photos.length} photo${gallery.data.photos.length === 1 ? '' : 's'}`}
                  </p>
                </div>
              </Link>
            </Card>
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center gap-y-3 rounded-xl border py-16">
          <p class="text-muted-foreground text-sm">No galleries yet.</p>
        </div>
      )
    }
  </section>
</Layout>
